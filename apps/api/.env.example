# ── FitTrack AI — FastAPI backend environment variables ───────────────────────
#
# Copy this file to .env for local development.
# Set these in Render → Environment for production.

APP_ENV=production

# PostgreSQL — Render provides this automatically via render.yaml Blueprint.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret keys — generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# CORS — set to your Vercel frontend URL (and localhost for local dev)
# JSON array of allowed origins:
BACKEND_CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# AI (optional — app works without this)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
