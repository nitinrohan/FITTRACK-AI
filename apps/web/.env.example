# ── FitTrack AI — Next.js frontend environment variables ──────────────────────
#
# Copy this file to .env.local for local development.
# Set these in Vercel → Settings → Environment Variables for production.

# URL of the deployed FastAPI backend (Render).
# In development this defaults to http://localhost:8000 via next.config.mjs rewrites.
# In production set this to your Render service URL, e.g.:
#   https://fittrack-api.onrender.com
NEXT_PUBLIC_API_URL=https://your-render-api-url.onrender.com

# Internal URL used for SSR requests (same as above or a private internal URL).
INTERNAL_API_URL=https://your-render-api-url.onrender.com
