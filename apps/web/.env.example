# ── FitTrack AI — Next.js frontend environment variables ──────────────────────
#
# Copy this file to .env.local for local development.
# Set these in Vercel → Settings → Environment Variables for production.

# URL of the deployed FastAPI backend (Railway).
# In development this defaults to http://localhost:8000 in next.config.ts.
# In production set this to your Railway service URL, e.g.:
#   https://fittrack-api-production.up.railway.app
NEXT_PUBLIC_API_URL=https://your-railway-api-url.up.railway.app

# Internal URL used for SSR requests (can be the same as above or a private
# Railway internal URL for faster in-network requests).
INTERNAL_API_URL=https://your-railway-api-url.up.railway.app
