# ============================================================
# FitTrack AI — Environment Configuration Example
# Copy this file to .env and fill in real values.
# Never commit .env with real secrets.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=fittrack
POSTGRES_USER=fittrack
POSTGRES_PASSWORD=changeme

# Assembled by docker-compose; override for external DBs.
DATABASE_URL=postgresql://fittrack:changeme@db:5432/fittrack

# ── Application ──────────────────────────────────────────────
APP_ENV=development          # development | production | test
APP_SECRET_KEY=change-this-to-a-long-random-secret-minimum-32-chars
LOG_LEVEL=INFO

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-different-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider (backend-only — never expose to frontend) ──
# Leave blank to run without AI features.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic        # anthropic | openai | none
AI_MODEL=claude-3-5-haiku-20241022

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# API URL as seen from the browser in development.
NEXT_PUBLIC_API_URL=http://localhost:8000
# API URL as seen from within the Next.js container (server-side).
INTERNAL_API_URL=http://api:8000

# ── CORS ────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
